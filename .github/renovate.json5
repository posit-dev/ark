{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  // Creates a tracking issue for all pending updates
  dependencyDashboard: true,

  // Avoid noisy notifications when Renovate rebases its own PRs
  suppressNotifications: ["prEditedNotification"],

  // Release weekly, a day after (potential) releases on Wednesdays
  timezone: "Europe/Brussels",
  schedule: ["before 8am on Thursday"],
  semanticCommits: "disabled",

  // Major updates get their own PR so they're easy to spot
  separateMajorMinor: true,

  // Wait 7 days before proposing an update to limit supply-chain risk
  minimumReleaseAge: "7 days",

  // We're reviewing and merging manually
  automerge: false,

  // Update Cargo dependencies, Github Actions, and Rust toolchains
  enabledManagers: ["cargo", "github-actions", "custom.regex"],

  cargo: {
    // Only bump Cargo.toml specifiers for major changes, let
    // minor/patch versions drift in the lockfile
    rangeStrategy: "replace",
  },

  packageRules: [
    // Group all crate updates into one weekly PR
    {
      groupName: "Rust crates",
      matchManagers: ["cargo"],
    },
    // Group all GitHub Actions updates into one weekly PR
    {
      groupName: "GitHub Actions",
      matchManagers: ["github-actions"],
    },
    // Don't bump runner versions (e.g. `runs-on: macos-14`)
    // since we intentionally test specific OS versions
    {
      matchManagers: ["github-actions"],
      matchDatasources: ["github-runners"],
      enabled: false,
    },
  ],

  // Track Rust toolchain updates from `rust-toolchain.toml`
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)rust-toolchain\\.toml?$/"],
      matchStrings: [
        "channel\\s*=\\s*\"(?<currentValue>\\d+\\.\\d+(\\.\\d+)?)\""
      ],
      depNameTemplate: "rust",
      packageNameTemplate: "rust-lang/rust",
      datasourceTemplate: "github-releases",
    },
  ],
}
